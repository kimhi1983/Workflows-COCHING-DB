# ============================================================
# 화장품 규제 수집 시스템 환경 설정
# ============================================================

# n8n 설정
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key-here

# Gemini API (n8n 크레덴셜에도 별도 설정 필요)
GEMINI_API_KEY=your-gemini-api-key

# Cloudflare (D1/KV/R2 사용 시)
CF_ACCOUNT_ID=your-cf-account-id
CF_API_TOKEN=your-cf-api-token

# Google Sheets 스프레드시트 ID (n8n 노드에서 설정)
GSHEET_ID=your-spreadsheet-id

# 알림 이메일 (Hiworks SMTP)
ALERT_EMAIL_TO=daniel@kpros.kr
SMTP_HOST=smtp.hiworks.com
SMTP_PORT=587
